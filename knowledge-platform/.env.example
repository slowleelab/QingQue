# ── 服务标识 ──
KP_ENVIRONMENT=development
KP_DEBUG=true
KP_LOG_LEVEL=INFO

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=kp_user
POSTGRES_PASSWORD=kp_pass
POSTGRES_DATABASE=knowledge_platform
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# ── Elasticsearch (BM25+IK + kNN 原生 RRF) ──
ES_HOSTS=http://localhost:9201
ES_INDEX_PREFIX=kp
ES_USERNAME=
ES_PASSWORD=
ES_VERIFY_CERTS=false

# ── MinIO ──
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kp-docs
MINIO_SECURE=false

# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_INGEST_TOPIC=kp.ingest.request
KAFKA_RESULT_TOPIC=kp.ingest.result
KAFKA_DLQ_TOPIC=kp.ingest.dlq
KAFKA_CONSUMER_GROUP=kp-worker
KAFKA_MAX_RETRIES=3

# ── Langfuse (LLM 可观测性，可选) ──
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── LLM (OpenAI 兼容，用于抽取) ──
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_PRIMARY_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60

# ── 嵌入服务 (TEI BGE-M3) ──
RAG_EMBEDDING_PROVIDER=tei
RAG_EMBEDDING_MODEL=BAAI/bge-M3
RAG_EMBEDDING_DIM=1024
RAG_EMBEDDING_BATCH_SIZE=128
RAG_TEI_BASE_URL=http://localhost:8082
RAG_EMBEDDING_TIMEOUT=30.0

# ── 重排服务 (TEI BGE-reranker-v2-m3) ──
RAG_RERANKER_PROVIDER=tei
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_TEI_RERANK_BASE_URL=http://localhost:8083

# ── 检索参数 ──
RAG_TOP_K=5
RAG_RERANK=true
RAG_RRF_K=60
RAG_CONFIDENCE_THRESHOLD=0.3
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=200

# ── 嵌入版本治理 ──
# 当前默认嵌入版本
RAG_EMBEDDING_MODEL_VERSION=bge-m3-v1
# 影子索引灰度版本（设为非空时检索自动过滤此版本，用于测试新模型）
RAG_SHADOW_MODEL_VERSION=

# ── 安全配置 ──
# API Key 认证（逗号分隔多个 Key，开发环境留空跳过认证）
SECURITY_API_KEYS=
# 敏感词词典文件路径（留空使用内置默认词库）
SECURITY_SENSITIVE_WORDS_PATH=
# 文件上传大小限制（MB）
SECURITY_MAX_UPLOAD_SIZE_MB=50
# 允许的文件扩展名（逗号分隔）
SECURITY_ALLOWED_FILE_EXTENSIONS=.pdf,.docx,.html,.htm,.md,.markdown,.txt,.xlsx
# 限流（每分钟每 IP 请求数）
SECURITY_RATE_LIMIT_PER_MINUTE=60
