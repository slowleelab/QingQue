<mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="600" math="0" shadow="0" background="#ffffff">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="系统架构图" style="text;html=1;fillColor=none;strokeColor=none;fontSize=18;fontStyle=1;fontColor=#111827;fontFamily=Helvetica Neue;" vertex="1" parent="1">
      <mxGeometry x="300" y="20" width="200" height="30" as="geometry"/>
    </mxCell>

    <!-- Node 1: 客户端 -->
    <mxCell id="client" value="客户端" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d1d5db;fontSize=14;fontColor=#111827;fontFamily=Helvetica Neue;" vertex="1" parent="1">
      <mxGeometry x="320" y="70" width="160" height="60" as="geometry"/>
    </mxCell>

    <!-- Node 2: API 网关 -->
    <mxCell id="gateway" value="API 网关" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#bfdbfe;fontSize=14;fontColor=#111827;fontFamily=Helvetica Neue;" vertex="1" parent="1">
      <mxGeometry x="320" y="200" width="160" height="60" as="geometry"/>
    </mxCell>

    <!-- Node 3: 订单服务 -->
    <mxCell id="order-svc" value="订单服务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d1d5db;fontSize=14;fontColor=#111827;fontFamily=Helvetica Neue;" vertex="1" parent="1">
      <mxGeometry x="320" y="330" width="160" height="60" as="geometry"/>
    </mxCell>

    <!-- Node 4: PostgreSQL -->
    <mxCell id="postgres" value="PostgreSQL" style="shape=cylinder3;size=10;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#86efac;fontSize=14;fontColor=#111827;fontFamily=Helvetica Neue;" vertex="1" parent="1">
      <mxGeometry x="320" y="460" width="160" height="70" as="geometry"/>
    </mxCell>

    <!-- Edge 1: Client → Gateway -->
    <mxCell id="e1" value="" style="endArrow=classic;edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2563eb;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="client" target="gateway">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edge 2: Gateway → Order Service -->
    <mxCell id="e2" value="" style="endArrow=classic;edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2563eb;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="gateway" target="order-svc">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edge 3: Order Service → PostgreSQL -->
    <mxCell id="e3" value="" style="endArrow=classic;edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#2563eb;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="order-svc" target="postgres">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>