{
  "dashboard": {
    "title": "SmartCS 服务监控面板",
    "tags": ["smartcs"],
    "timezone": "browser",
    "panels": [
      {
        "title": "请求 QPS",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "sum(rate(http_requests_total{app=~\"smartcs.*\"}[1m])) by (app)", "legendFormat": "{{app}}" }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
      },
      {
        "title": "请求延迟 P95",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app=~\"smartcs.*\"}[5m])) by (le, app))", "legendFormat": "{{app}}" }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
      },
      {
        "title": "错误率",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "sum(rate(http_requests_total{app=~\"smartcs.*\",status=~\"5..\"}[1m])) / sum(rate(http_requests_total{app=~\"smartcs.*\"}[1m])) * 100", "legendFormat": "Error %" }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
      },
      {
        "title": "限流拒绝数",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "sum(rate(http_requests_total{app=~\"smartcs.*\",status=\"429\"}[1m]))", "legendFormat": "Rate Limited" }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
      },
      {
        "title": "HTTP 请求延迟分布",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{app=~\"smartcs.*\"}[5m])) by (le, app))", "legendFormat": "P50 {{app}}" },
          { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app=~\"smartcs.*\"}[5m])) by (le, app))", "legendFormat": "P95 {{app}}" },
          { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{app=~\"smartcs.*\"}[5m])) by (le, app))", "legendFormat": "P99 {{app}}" }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
      },
      {
        "title": "会话状态分布",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "smartcs_session_transitions_total", "legendFormat": "{{phase}} transitions" }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
      },
      {
        "title": "LLM 推理延迟",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "histogram_quantile(0.95, sum(rate(smartcs_llm_inference_duration_seconds_bucket[5m])) by (le))", "legendFormat": "LLM P95" }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
      },
      {
        "title": "检索延迟",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "histogram_quantile(0.95, sum(rate(smartcs_retrieval_duration_seconds_bucket[5m])) by (le, search_type))", "legendFormat": "{{search_type}} P95" }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
      },
      {
        "title": "降级状态",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "smartcs_degradation_level", "legendFormat": "Level (0=normal,1=degraded,2=fallback)" }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 }
      },
      {
        "title": "会话超时计数",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "sum(rate(smartcs_session_timeouts_total[5m])) by (reason)", "legendFormat": "{{reason}}" }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 }
      },
      {
        "title": "Bot Worker 队列",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "smartcs_bot_stream_length", "legendFormat": "Stream Length" },
          { "expr": "smartcs_bot_active_workers", "legendFormat": "Active Workers" }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 }
      },
      {
        "title": "Agent 并发槽位",
        "type": "gauge",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "smartcs_bot_agent_slots_available", "legendFormat": "Available" }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 }
      }
    ]
  }
}
