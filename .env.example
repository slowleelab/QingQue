# ── SmartCS 环境变量配置 ──
# 复制此文件为 .env 并根据环境修改
# cp .env.example .env

# ── 全局 ──
SMARTCS_ENVIRONMENT=development
SMARTCS_DEBUG=true
SMARTCS_LOG_LEVEL=INFO
SMARTCS_SERVICE_HOST=127.0.0.1
SMARTCS_STAR_CONNECTION_URL=http://localhost:8080
SMARTCS_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# ── Bot 服务 ──
BOT_MAX_CONCURRENT_AGENTS=10
BOT_MESSAGE_TTL_SECONDS=8
BOT_FAST_REPLY_COOLDOWN=5

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=smartcs
POSTGRES_PASSWORD=smartcs_pass
POSTGRES_DATABASE=smartcs

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# ── Elasticsearch ──
ES_HOSTS=http://localhost:9200
# 安全认证已关闭（开发环境），以下字段仅生产环境使用
# ES_USERNAME=elastic
# ES_PASSWORD=elastic_pass

# ── Milvus ──
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ── MinIO ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# ── LLM (Ollama) ──
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_PRIMARY_MODEL=qwen2.5:7b
LLM_FALLBACK_MODEL=qwen2.5:0.5b

# ── gRPC 服务 ──
CLS_GRPC_HOST=localhost
CLS_GRPC_PORT=50051
RAG_GRPC_HOST=localhost
RAG_GRPC_PORT=50052
SAFETY_GRPC_HOST=localhost
SAFETY_GRPC_PORT=50053

# ── 坐席辅助 ──
ASSIST_SCRIPT_TIMEOUT_MS=500
ASSIST_KNOWLEDGE_TIMEOUT_MS=600
ASSIST_ALERT_TIMEOUT_MS=300
ASSIST_PRODUCT_TIMEOUT_MS=400
ASSIST_THROTTLE_WINDOW_MS=800

# ── Docker Compose 中间件密码 ──
# 这些值被 docker-compose.yml 引用
POSTGRES_PASSWORD_DOCKER=smartcs_pass
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
